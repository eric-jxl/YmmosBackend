# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev# development | production
APP_NAME=Backend
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true
APP_WORKERS=4

# ─── Database ─────────────────────────────────────────────────────────────────
# 选择一种数据库驱动，注释掉其余两个

# SQLite（默认，无需额外配置）
DATABASE_URL=sqlite+aiosqlite:///sqlmodel.db

# MySQL / MariaDB（需安装 asyncmy，已包含于依赖）
# DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/ymmos_db?charset=utf8mb4

# PostgreSQL（需安装 asyncpg，已包含于依赖）
# DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5432/ymmos_db

# 连接池（SQLite 忽略此配置，MySQL/PostgreSQL 生效）
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── GitHub OAuth2 ────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-domain.com/api/v1/auth/github/callback

# ─── TOTP 速率限制 ─────────────────────────────────────────────────────────────
TOTP_MAX_FAILURES=3
TOTP_LOCKOUT_SECONDS=60
